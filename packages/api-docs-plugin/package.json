{
	"name": "@honestjs/api-docs-plugin",
	"version": "1.2.0",
	"description": "API Docs plugin for HonestJS - generates OpenAPI from artifact object or context key and serves Swagger UI",
	"main": "./dist/index.js",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"clean": "rm -rf dist",
		"type-check": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "prettier --check .",
		"prepack": "pnpm run build"
	},
	"keywords": [
		"honestjs",
		"hono",
		"swagger",
		"openapi",
		"api-docs"
	],
	"author": "Orkhan Karimov <karimovok1@gmail.com> (https://github.com/kerimovok)",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/honestjs/plugins.git",
		"directory": "packages/api-docs-plugin"
	},
	"devDependencies": {
		"honestjs": "^0.1.13",
		"hono": "^4.12.8",
		"reflect-metadata": "^0.2.2",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"openapi-types": "^12.1.3"
	},
	"peerDependencies": {
		"honestjs": "^0.1.11",
		"hono": "^4.0.0",
		"typescript": "^5.x"
	}
}
